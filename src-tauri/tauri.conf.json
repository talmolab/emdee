{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "emdee",
  "version": "0.1.3",
  "identifier": "com.emdee.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "emdee",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: https:; media-src 'self' asset: http://asset.localhost data:; font-src 'self' data:; connect-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/talmolab/emdee/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGQTE1NkY5QzkxRjFBQjMKUldTekdoL0orVmFoTDBGQ3BmSDFYeXN3cmUrTk5LdytlUXVtaWdkdzJsZHNVT2cxODd2ek43U1UK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdx"],
        "mimeType": "text/markdown",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./nsis/hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["./wix/path.wxs"],
        "componentRefs": ["PathEntry"]
      }
    }
  }
}
